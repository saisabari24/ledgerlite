// LedgerLite - Multi-tenant Bookkeeping Platform
// Prisma Schema - PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTH & TENANT ============

enum UserRole {
  BUSINESS
  CA
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  tenantId     String?  @map("tenant_id") // Business users belong to a tenant
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant   Tenant?    @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  caAccess CaAccess[]
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  gstin     String?  @unique
  pan       String?
  currency  String   @default("INR")
  logoUrl      String? @map("logo_url")
  address      String?
  city         String?
  state        String?
  pincode      String?
  phone        String?
  tenantEmail  String? @map("tenant_email")
  termsAndConditions String? @map("terms_and_conditions")
  bankName         String? @map("bank_name")
  bankAccountName  String? @map("bank_account_name")
  bankAccountNumber String? @map("bank_account_number")
  bankIfsc         String? @map("bank_ifsc")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

   users           User[]
   caAccess        CaAccess[]
   accounts        Account[]
   journalEntries  JournalEntry[]
   documents       Document[]
   printTemplates  PrintTemplate[]
   items           Item[]
   stockMovements  StockMovement[]
}

enum PermissionLevel {
  VIEW
  EDIT
  FULL
}

model CaAccess {
  id              String          @id @default(cuid())
  caUserId        String          @map("ca_user_id")
  tenantId        String          @map("tenant_id")
  permissionLevel PermissionLevel @default(EDIT) @map("permission_level")
  createdAt       DateTime        @default(now()) @map("created_at")

  caUser User  @relation(fields: [caUserId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([caUserId, tenantId])
  @@map("ca_access")
}

// ============ ACCOUNTING ============

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

model Account {
  id        String      @id @default(cuid())
  tenantId  String      @map("tenant_id")
  code      String
  name      String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(18, 2)
  isGroup   Boolean     @default(false) @map("is_group")
  parentId  String?     @map("parent_id")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

   tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   journalLines JournalLine[]
   parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
   children     Account[]     @relation("AccountHierarchy")
   stockFromLines StockMovementLine[] @relation("StockFromAccount")
   stockToLines   StockMovementLine[] @relation("StockToAccount")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, parentId])
}

enum JournalStatus {
  DRAFT
  POSTED
  CANCELLED
}

model JournalEntry {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  date        DateTime      @db.Date
  description String?
  status      JournalStatus @default(DRAFT)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines         JournalLine[]
  documents     Document[]
  stockMovement StockMovement?

  @@index([tenantId])
  @@index([tenantId, date])
}

model Document {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  filename       String   @map("filename")
  originalName   String   @map("original_name")
  mimeType       String   @map("mime_type")
  size           Int
  storagePath    String   @map("storage_path")
  journalEntryId String?  @map("journal_entry_id")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([journalEntryId])
}

model JournalLine {
  id             String   @id @default(cuid())
  journalEntryId String   @map("journal_entry_id")
  accountId      String   @map("account_id")
  debit          Decimal  @default(0) @db.Decimal(18, 2)
  credit         Decimal  @default(0) @db.Decimal(18, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account     @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalEntryId])
  @@index([accountId])
}

// ============ PRINT TEMPLATES ============

enum PrintTemplateType {
  SALES_INVOICE
  PURCHASE_INVOICE
  QUOTE
  PAYMENT
}

model PrintTemplate {
  id        String           @id @default(cuid())
  tenantId  String           @map("tenant_id")
  name      String
  type      PrintTemplateType
  isDefault Boolean          @default(false) @map("is_default")
  isCustom  Boolean          @default(true) @map("is_custom")
  engine    String           @default("HTML")
  body      String
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

   @@index([tenantId])
   @@index([tenantId, type, isDefault])
   @@unique([tenantId, name], map: "print_template_tenant_name_unique")
}

// ============ INVENTORY ============

enum StockMovementType {
   TRANSFER
   ADJUSTMENT
   OPENING_BALANCE
}

model Item {
   id          String   @id @default(cuid())
   tenantId    String   @map("tenant_id")
   code        String
   name        String
   unit        String   @default("nos")
   rate        Decimal  @default(0) @db.Decimal(18, 2)
   description String?
   createdAt   DateTime @default(now()) @map("created_at")
   updatedAt   DateTime @updatedAt @map("updated_at")

   tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   stockMovementLines  StockMovementLine[]

   @@unique([tenantId, code])
   @@index([tenantId])
}

model StockMovement {
   id            String            @id @default(cuid())
   tenantId      String            @map("tenant_id")
   movementNo    String            @map("movement_no")
   status        JournalStatus     @default(DRAFT)
   date          DateTime          @db.Date
   movementType  StockMovementType @default(TRANSFER) @map("movement_type")
   description   String?
   journalEntryId String?          @unique @map("journal_entry_id")
   createdAt     DateTime          @default(now()) @map("created_at")
   updatedAt     DateTime          @updatedAt @map("updated_at")

   tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   lines        StockMovementLine[]
   journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

   @@index([tenantId])
   @@index([tenantId, date])
   @@index([tenantId, movementNo])
}

model StockMovementLine {
   id               String   @id @default(cuid())
   stockMovementId  String   @map("stock_movement_id")
   itemId           String   @map("item_id")
   quantity         Decimal  @default(0) @db.Decimal(18, 2)
   fromAccountId    String?  @map("from_account_id")
   toAccountId      String?  @map("to_account_id")
   createdAt        DateTime @default(now()) @map("created_at")

   stockMovement  StockMovement @relation(fields: [stockMovementId], references: [id], onDelete: Cascade)
   item           Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
   fromAccount    Account?      @relation("StockFromAccount", fields: [fromAccountId], references: [id], onDelete: Restrict)
   toAccount      Account?      @relation("StockToAccount", fields: [toAccountId], references: [id], onDelete: Restrict)

   @@index([stockMovementId])
   @@index([itemId])
}
