// LedgerLite - Multi-tenant Bookkeeping Platform
// Prisma Schema - PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTH & TENANT ============

enum UserRole {
  BUSINESS
  CA
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  tenantId     String?  @map("tenant_id") // Business users belong to a tenant
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant   Tenant?    @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  caAccess CaAccess[]
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  gstin     String?  @unique
  pan       String?
  currency  String   @default("INR")
  logoUrl      String? @map("logo_url")
  address      String?
  city         String?
  state        String?
  pincode      String?
  phone        String?
  tenantEmail  String? @map("tenant_email")
  termsAndConditions String? @map("terms_and_conditions")
  bankName         String? @map("bank_name")
  bankAccountName  String? @map("bank_account_name")
  bankAccountNumber String? @map("bank_account_number")
  bankIfsc         String? @map("bank_ifsc")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

   users           User[]
   caAccess        CaAccess[]
   accounts        Account[]
   journalEntries  JournalEntry[]
   documents       Document[]
   printTemplates  PrintTemplate[]
    items           Item[]
    stockMovements  StockMovement[]
    customers       Customer[]
    suppliers       Supplier[]
    salesQuotes     SalesQuote[]
    salesInvoices   SalesInvoice[]
    salesPayments   SalesPayment[]
    purchaseInvoices PurchaseInvoice[]
    purchasePayments PurchasePayment[]
}

enum PermissionLevel {
  VIEW
  EDIT
  FULL
}

model CaAccess {
  id              String          @id @default(cuid())
  caUserId        String          @map("ca_user_id")
  tenantId        String          @map("tenant_id")
  permissionLevel PermissionLevel @default(EDIT) @map("permission_level")
  createdAt       DateTime        @default(now()) @map("created_at")

  caUser User  @relation(fields: [caUserId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([caUserId, tenantId])
  @@map("ca_access")
}

// ============ ACCOUNTING ============

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

model Account {
  id        String      @id @default(cuid())
  tenantId  String      @map("tenant_id")
  code      String
  name      String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(18, 2)
  isGroup   Boolean     @default(false) @map("is_group")
  parentId  String?     @map("parent_id")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

   tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   journalLines JournalLine[]
   parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
   children     Account[]     @relation("AccountHierarchy")
   stockFromLines StockMovementLine[] @relation("StockFromAccount")
   stockToLines   StockMovementLine[] @relation("StockToAccount")
   salesInvoiceLines SalesInvoiceLine[] @relation("SalesInvoiceAccount")
   purchaseInvoiceLines PurchaseInvoiceLine[] @relation("PurchaseInvoiceAccount")
   salesPayments    SalesPayment[]      @relation("SalesPaymentAccount")
   purchasePayments PurchasePayment[]   @relation("PurchasePaymentAccount")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, parentId])
}

enum JournalStatus {
  DRAFT
  POSTED
  CANCELLED
}

model JournalEntry {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  date        DateTime      @db.Date
  description String?
  status      JournalStatus @default(DRAFT)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines         JournalLine[]
  documents     Document[]
  stockMovement StockMovement?
  salesInvoice  SalesInvoice?
  purchaseInvoice PurchaseInvoice?
  salesPayment  SalesPayment?
  purchasePayment PurchasePayment?

  @@index([tenantId])
  @@index([tenantId, date])
}

model Document {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  filename       String   @map("filename")
  originalName   String   @map("original_name")
  mimeType       String   @map("mime_type")
  size           Int
  storagePath    String   @map("storage_path")
  journalEntryId String?  @map("journal_entry_id")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([journalEntryId])
}

model JournalLine {
  id             String   @id @default(cuid())
  journalEntryId String   @map("journal_entry_id")
  accountId      String   @map("account_id")
  debit          Decimal  @default(0) @db.Decimal(18, 2)
  credit         Decimal  @default(0) @db.Decimal(18, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account     @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalEntryId])
  @@index([accountId])
}

// ============ PRINT TEMPLATES ============

enum PrintTemplateType {
  SALES_INVOICE
  PURCHASE_INVOICE
  QUOTE
  PAYMENT
}

model PrintTemplate {
  id        String           @id @default(cuid())
  tenantId  String           @map("tenant_id")
  name      String
  type      PrintTemplateType
  isDefault Boolean          @default(false) @map("is_default")
  isCustom  Boolean          @default(true) @map("is_custom")
  engine    String           @default("HTML")
  body      String
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

   @@index([tenantId])
   @@index([tenantId, type, isDefault])
   @@unique([tenantId, name], map: "print_template_tenant_name_unique")
}

// ============ INVENTORY ============

enum StockMovementType {
   TRANSFER
   ADJUSTMENT
   OPENING_BALANCE
}

model Item {
   id          String   @id @default(cuid())
   tenantId    String   @map("tenant_id")
   code        String
   name        String
   unit        String   @default("nos")
   rate        Decimal  @default(0) @db.Decimal(18, 2)
   taxRate     Decimal  @default(0) @db.Decimal(5, 2) @map("tax_rate")
   description String?
   createdAt   DateTime @default(now()) @map("created_at")
   updatedAt   DateTime @updatedAt @map("updated_at")

   tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   stockMovementLines   StockMovementLine[]
   salesQuoteLines      SalesQuoteLine[]
   salesInvoiceLines    SalesInvoiceLine[]
   purchaseInvoiceLines PurchaseInvoiceLine[]

   @@unique([tenantId, code])
   @@index([tenantId])
}

model StockMovement {
   id            String            @id @default(cuid())
   tenantId      String            @map("tenant_id")
   movementNo    String            @map("movement_no")
   status        JournalStatus     @default(DRAFT)
   date          DateTime          @db.Date
   movementType  StockMovementType @default(TRANSFER) @map("movement_type")
   description   String?
   journalEntryId String?          @unique @map("journal_entry_id")
   createdAt     DateTime          @default(now()) @map("created_at")
   updatedAt     DateTime          @updatedAt @map("updated_at")

   tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   lines        StockMovementLine[]
   journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

   @@index([tenantId])
   @@index([tenantId, date])
   @@index([tenantId, movementNo])
}

model StockMovementLine {
   id               String   @id @default(cuid())
   stockMovementId  String   @map("stock_movement_id")
   itemId           String   @map("item_id")
   quantity         Decimal  @default(0) @db.Decimal(18, 2)
   fromAccountId    String?  @map("from_account_id")
   toAccountId      String?  @map("to_account_id")
   createdAt        DateTime @default(now()) @map("created_at")

   stockMovement  StockMovement @relation(fields: [stockMovementId], references: [id], onDelete: Cascade)
   item           Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
   fromAccount    Account?      @relation("StockFromAccount", fields: [fromAccountId], references: [id], onDelete: Restrict)
   toAccount      Account?      @relation("StockToAccount", fields: [toAccountId], references: [id], onDelete: Restrict)

   @@index([stockMovementId])
   @@index([itemId])
}

// ============ PARTIES ============

model Customer {
   id       String   @id @default(cuid())
   tenantId String   @map("tenant_id")
   name     String
   email    String?
   phone    String?
   gstin    String?
   pan      String?
   address  String?
   city     String?
   state    String?
   pincode  String?
   balance  Decimal  @default(0) @db.Decimal(18, 2)
   createdAt DateTime @default(now()) @map("created_at")
   updatedAt DateTime @updatedAt @map("updated_at")

   tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   salesQuotes   SalesQuote[]
   salesInvoices SalesInvoice[]
   salesPayments SalesPayment[]

   @@index([tenantId])
}

model Supplier {
   id       String   @id @default(cuid())
   tenantId String   @map("tenant_id")
   name     String
   email    String?
   phone    String?
   gstin    String?
   pan      String?
   address  String?
   city     String?
   state    String?
   pincode  String?
   balance  Decimal  @default(0) @db.Decimal(18, 2)
   createdAt DateTime @default(now()) @map("created_at")
   updatedAt DateTime @updatedAt @map("updated_at")

   tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   purchaseInvoices PurchaseInvoice[]
   purchasePayments PurchasePayment[]

   @@index([tenantId])
}

// ============ SALES ============

enum SalesQuoteStatus {
   DRAFT
   SENT
   ACCEPTED
   EXPIRED
}

model SalesQuote {
   id         String          @id @default(cuid())
   tenantId   String          @map("tenant_id")
   quoteNo    String          @map("quote_no")
   date       DateTime        @db.Date
   customerId String          @map("customer_id")
   status     SalesQuoteStatus @default(DRAFT)
   subtotal   Decimal         @default(0) @db.Decimal(18, 2)
   tax        Decimal         @default(0) @db.Decimal(18, 2)
   total      Decimal         @default(0) @db.Decimal(18, 2)
   description String?
   createdAt  DateTime        @default(now()) @map("created_at")
   updatedAt  DateTime        @updatedAt @map("updated_at")

   tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   customer Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
   lines    SalesQuoteLine[]

   @@index([tenantId])
   @@index([tenantId, quoteNo])
}

model SalesQuoteLine {
   id           String   @id @default(cuid())
   salesQuoteId String   @map("sales_quote_id")
   itemId       String   @map("item_id")
   description  String?
   quantity     Decimal  @default(1) @db.Decimal(18, 2)
   rate         Decimal  @default(0) @db.Decimal(18, 2)
   taxRate      Decimal  @default(0) @db.Decimal(5, 2) @map("tax_rate")
   amount       Decimal  @default(0) @db.Decimal(18, 2)
   createdAt    DateTime @default(now()) @map("created_at")

   salesQuote SalesQuote @relation(fields: [salesQuoteId], references: [id], onDelete: Cascade)
   item       Item       @relation(fields: [itemId], references: [id], onDelete: Restrict)

   @@index([salesQuoteId])
}

enum SalesInvoiceStatus {
   DRAFT
   UNPAID
   PARTIALLY_PAID
   PAID
}

model SalesInvoice {
   id             String             @id @default(cuid())
   tenantId       String             @map("tenant_id")
   invoiceNo      String             @map("invoice_no")
   date           DateTime           @db.Date
   dueDate        DateTime?          @db.Date @map("due_date")
   customerId     String             @map("customer_id")
   status         SalesInvoiceStatus @default(DRAFT)
   subtotal       Decimal            @default(0) @db.Decimal(18, 2)
   tax            Decimal            @default(0) @db.Decimal(18, 2)
   total          Decimal            @default(0) @db.Decimal(18, 2)
   description    String?
   terms          String?
   journalEntryId String?            @unique @map("journal_entry_id")
   createdAt      DateTime           @default(now()) @map("created_at")
   updatedAt      DateTime           @updatedAt @map("updated_at")

   tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   customer     Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
   lines        SalesInvoiceLine[]
   journalEntry JournalEntry?   @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
   allocations  SalesPaymentAllocation[]

   @@index([tenantId])
   @@index([tenantId, invoiceNo])
}

model SalesInvoiceLine {
   id             String   @id @default(cuid())
   salesInvoiceId String   @map("sales_invoice_id")
   itemId         String   @map("item_id")
   accountId      String?  @map("account_id")
   description    String?
   quantity       Decimal  @default(1) @db.Decimal(18, 2)
   rate           Decimal  @default(0) @db.Decimal(18, 2)
   taxRate        Decimal  @default(0) @db.Decimal(5, 2) @map("tax_rate")
   amount         Decimal  @default(0) @db.Decimal(18, 2)
   createdAt      DateTime @default(now()) @map("created_at")

   salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
   item         Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)
   account      Account?     @relation("SalesInvoiceAccount", fields: [accountId], references: [id], onDelete: Restrict)

   @@index([salesInvoiceId])
}

model SalesPayment {
   id             String   @id @default(cuid())
   tenantId       String   @map("tenant_id")
   paymentNo      String   @map("payment_no")
   date           DateTime @db.Date
   customerId     String   @map("customer_id")
   mode           String
   reference      String?
   amount         Decimal  @default(0) @db.Decimal(18, 2)
   accountId      String?  @map("account_id")
   journalEntryId String?  @unique @map("journal_entry_id")
   createdAt      DateTime @default(now()) @map("created_at")
   updatedAt      DateTime @updatedAt @map("updated_at")

   tenant       Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   customer     Customer                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
   account      Account?                 @relation("SalesPaymentAccount", fields: [accountId], references: [id], onDelete: Restrict)
   journalEntry JournalEntry?            @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
   allocations  SalesPaymentAllocation[]

   @@index([tenantId])
}

model SalesPaymentAllocation {
   id             String  @id @default(cuid())
   salesPaymentId String  @map("sales_payment_id")
   salesInvoiceId String  @map("sales_invoice_id")
   amount         Decimal @default(0) @db.Decimal(18, 2)
   createdAt      DateTime @default(now()) @map("created_at")

   salesPayment SalesPayment @relation(fields: [salesPaymentId], references: [id], onDelete: Cascade)
   salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Restrict)

   @@unique([salesPaymentId, salesInvoiceId])
   @@index([salesPaymentId])
}

// ============ PURCHASES ============

enum PurchaseInvoiceStatus {
   DRAFT
   UNPAID
   PARTIALLY_PAID
   PAID
}

model PurchaseInvoice {
   id             String                @id @default(cuid())
   tenantId       String                @map("tenant_id")
   invoiceNo      String                @map("invoice_no")
   date           DateTime              @db.Date
   dueDate        DateTime?             @db.Date @map("due_date")
   supplierId     String                @map("supplier_id")
   status         PurchaseInvoiceStatus @default(DRAFT)
   subtotal       Decimal               @default(0) @db.Decimal(18, 2)
   tax            Decimal               @default(0) @db.Decimal(18, 2)
   total          Decimal               @default(0) @db.Decimal(18, 2)
   description    String?
   terms          String?
   journalEntryId String?               @unique @map("journal_entry_id")
   createdAt      DateTime              @default(now()) @map("created_at")
   updatedAt      DateTime              @updatedAt @map("updated_at")

   tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   supplier     Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
   lines        PurchaseInvoiceLine[]
   journalEntry JournalEntry?         @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
   allocations  PurchasePaymentAllocation[]

   @@index([tenantId])
   @@index([tenantId, invoiceNo])
}

model PurchaseInvoiceLine {
   id                String   @id @default(cuid())
   purchaseInvoiceId String   @map("purchase_invoice_id")
   itemId            String   @map("item_id")
   accountId         String?  @map("account_id")
   description       String?
   quantity          Decimal  @default(1) @db.Decimal(18, 2)
   rate              Decimal  @default(0) @db.Decimal(18, 2)
   taxRate           Decimal  @default(0) @db.Decimal(5, 2) @map("tax_rate")
   amount            Decimal  @default(0) @db.Decimal(18, 2)
   createdAt         DateTime @default(now()) @map("created_at")

   purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
   item            Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)
   account         Account?        @relation("PurchaseInvoiceAccount", fields: [accountId], references: [id], onDelete: Restrict)

   @@index([purchaseInvoiceId])
}

model PurchasePayment {
   id             String   @id @default(cuid())
   tenantId       String   @map("tenant_id")
   paymentNo      String   @map("payment_no")
   date           DateTime @db.Date
   supplierId     String   @map("supplier_id")
   mode           String
   reference      String?
   amount         Decimal  @default(0) @db.Decimal(18, 2)
   accountId      String?  @map("account_id")
   journalEntryId String?  @unique @map("journal_entry_id")
   createdAt      DateTime @default(now()) @map("created_at")
   updatedAt      DateTime @updatedAt @map("updated_at")

   tenant       Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   supplier     Supplier                   @relation(fields: [supplierId], references: [id], onDelete: Restrict)
   account      Account?                   @relation("PurchasePaymentAccount", fields: [accountId], references: [id], onDelete: Restrict)
   journalEntry JournalEntry?              @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
   allocations  PurchasePaymentAllocation[]

   @@index([tenantId])
}

model PurchasePaymentAllocation {
   id                 String  @id @default(cuid())
   purchasePaymentId  String  @map("purchase_payment_id")
   purchaseInvoiceId  String  @map("purchase_invoice_id")
   amount             Decimal @default(0) @db.Decimal(18, 2)
   createdAt          DateTime @default(now()) @map("created_at")

   purchasePayment  PurchasePayment @relation(fields: [purchasePaymentId], references: [id], onDelete: Cascade)
   purchaseInvoice  PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Restrict)

   @@unique([purchasePaymentId, purchaseInvoiceId])
   @@index([purchasePaymentId])
}
